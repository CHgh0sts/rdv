# PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# URL publique (runtime, prioritaire — pas figée au build)
APP_URL="https://rdv.chghosts.fr"

# Fallback client (éviter localhost en prod si APP_URL est défini)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Spotify Developer Dashboard — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
# Optionnel — sinon dérivé auto depuis APP_URL ou headers de la requête
SPOTIFY_REDIRECT_URI="https://rdv.chghosts.fr/api/spotify/callback"
